# Copier en "terraform.tfvars" et remplir (ignore par git).
tenancy_ocid     = "ocid1.tenancy.oc1..xxxxxxxx"
compartment_ocid = "ocid1.tenancy.oc1..xxxxxxxx"
region           = "uk-london-1"

cluster_name       = "bloom-oke"
kubernetes_version = "v1.33.1"

# Architecture des workers : "arm" (A1.Flex gratuit) ou "amd" (E5.Flex)
node_arch       = "amd"
node_count      = 2
node_ocpus      = 2
node_memory_gbs = 16
